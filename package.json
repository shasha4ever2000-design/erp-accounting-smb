{
  "name": "erp-accounting-smb",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "Professional double-entry ERP & accounting for small and medium businesses.",
  "author": "ERP Accounting",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "vite build",
    "electron:dev": "vite build && electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.441.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.shasha.erpaccounting",
    "productName": "ERP Accounting",
    "files": [
      "electron/**/*",
      "dist-electron-web/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
